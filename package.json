{
  "name": "@clawpage.ai/cli",
  "version": "0.4.1",
  "description": "Generative UI hosting CLI — publish single-file HTML pages from Claude Code, Codex, or Gemini CLI to a hosted URL. Runtime for the clawpage skill / plugin. Manages pages, short links, KV data tables, blob storage (R2), and view stats.",
  "type": "module",
  "bin": {
    "clawpage": "bin/clawpage.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://clawpage.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clawpage/clawpage-cli.git"
  },
  "bugs": {
    "url": "https://github.com/clawpage/clawpage-cli/issues"
  },
  "keywords": [
    "clawpage",
    "publish",
    "cli",
    "claude-code",
    "claude-artifact",
    "codex",
    "gemini-cli",
    "copilot-cli",
    "skill",
    "plugin",
    "agent-skill",
    "generative-ui",
    "ai-hosting",
    "single-file-html",
    "html-hosting",
    "static-hosting",
    "ai-agent"
  ],
  "publishConfig": {
    "access": "public"
  }
}
